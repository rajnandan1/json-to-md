{
  "name": "@rajnandan1/json-to-md",
  "version": "3.0.0",
  "description": "Convert one JSON document into deterministic, human-readable GitHub Flavored Markdown.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajnandan1/json-to-md.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "demo": "vite demo"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fast-check": "^3.23.0",
    "github-slugger": "^2.0.0",
    "marked": "^15.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^8.1.5",
    "vitest": "^2.1.8"
  }
}
